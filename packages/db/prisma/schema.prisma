generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  super_admin
  owner
  staff
}

enum TenantCategory {
  restaurant
  retail
  liquor
  clinic
  salon
  hotel
  gym
  cafe
  other
}

enum TenantPlan {
  free
  starter
  pro
  business
}

enum TenantStatus {
  active
  suspended
  trial
}

enum IntegrationProvider {
  google
  yelp
  facebook
}

enum IntegrationStatus {
  connected
  error
  disconnected
}

enum ReviewProvider {
  google
  yelp
  facebook
  native
}

enum ReviewSentiment {
  positive
  neutral
  negative
}

enum ReviewStatus {
  new
  read
  flagged
  resolved
}

enum ReplyStatus {
  draft
  sent
  failed
}

enum RequestChannel {
  sms
  email
  qr
}

enum RequestStatus {
  queued
  sent
  delivered
  opened
  clicked
  submitted
  failed
}

enum CampaignTrigger {
  manual
  schedule
  webhook
}

enum CampaignStatus {
  draft
  active
  paused
  completed
}

enum TemplateChannel {
  sms
  email
}

enum UsageKind {
  ai_tokens
  sms
  email
}

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String?
  name            String
  phone           String?
  role            UserRole
  tenantId        String?
  emailVerifiedAt DateTime?
  twoFactorSecret String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant         Tenant?       @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  authoredReplies ReviewReply[] @relation("ReplyAuthor")
  auditLogs      AuditLog[]     @relation("AuditActor")

  @@index([tenantId])
  @@index([role])
}

model Tenant {
  id               String         @id @default(cuid())
  name             String
  category         TenantCategory
  plan             TenantPlan
  status           TenantStatus
  stripeCustomerId String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  users        User[]
  locations    Location[]
  customers    Customer[]
  campaigns    Campaign[]
  templates    Template[]
  auditLogs    AuditLog[]
  subscription Subscription?
  usage        Usage[]
  apiKeys      ApiKey[]
}

model Location {
  id             String   @id @default(cuid())
  tenantId       String
  name           String
  slug           String   @unique
  address        String
  phone          String?
  timezone       String
  googlePlaceId  String?
  yelpBusinessId String?
  fbPageId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  integrations   Integration[]
  reviews        Review[]
  reviewRequests ReviewRequest[]

  @@index([tenantId])
}

model Integration {
  id              String            @id @default(cuid())
  locationId      String
  provider        IntegrationProvider
  accessTokenEnc  String?
  refreshTokenEnc String?
  expiresAt       DateTime?
  status          IntegrationStatus
  meta            Json
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@index([locationId, provider])
}

model Review {
  id              String          @id @default(cuid())
  locationId      String
  provider        ReviewProvider
  providerReviewId String
  rating          Int
  title           String?
  body            String
  authorName      String
  authorAvatarUrl String?
  language        String?
  postedAt        DateTime
  fetchedAt       DateTime
  sentiment       ReviewSentiment?
  sentimentScore  Float?
  topics          String[]
  status          ReviewStatus    @default(new)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  location Location      @relation(fields: [locationId], references: [id], onDelete: Cascade)
  replies  ReviewReply[]

  @@unique([locationId, provider, providerReviewId])
  @@index([locationId, postedAt])
  @@index([status])
}

model ReviewReply {
  id            String      @id @default(cuid())
  reviewId      String
  authorUserId  String?
  body          String
  status        ReplyStatus
  isAiSuggested Boolean
  tone          String?
  sentAt        DateTime?
  providerError String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  review  Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  author  User?  @relation("ReplyAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([reviewId])
}

model Customer {
  id           String   @id @default(cuid())
  tenantId     String
  name         String
  email        String?
  phone        String?
  tags         String[]
  consentSms   Boolean
  consentEmail Boolean
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reviewRequests ReviewRequest[]

  @@index([tenantId])
}

model ReviewRequest {
  id                String        @id @default(cuid())
  locationId        String
  customerId        String
  channel           RequestChannel
  status            RequestStatus
  sentAt            DateTime?
  openedAt          DateTime?
  clickedAt         DateTime?
  submittedReviewId String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  location Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([locationId, status])
  @@index([customerId])
}

model Campaign {
  id         String          @id @default(cuid())
  tenantId   String
  name       String
  templateId String
  trigger    CampaignTrigger
  schedule   String?
  status     CampaignStatus
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  template Template @relation(fields: [templateId], references: [id], onDelete: Restrict)

  @@index([tenantId, status])
}

model Template {
  id        String          @id @default(cuid())
  tenantId  String
  channel   TemplateChannel
  subject   String?
  body      String
  variables String[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaigns Campaign[]

  @@index([tenantId, channel])
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  actorUserId String?
  action      String
  targetType  String
  targetId    String?
  metadata    Json
  at          DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor  User?  @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, at])
}

model Subscription {
  id                 String   @id @default(cuid())
  tenantId           String   @unique
  stripeCustomerId   String
  stripeSubId        String
  plan               String
  status             String
  currentPeriodEnd   DateTime
  aiCreditsRemaining Int
  smsCreditsRemaining Int
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Usage {
  id        String    @id @default(cuid())
  tenantId  String
  kind      UsageKind
  amount    Int
  cost      Decimal   @db.Decimal(12, 4)
  meta      Json
  at        DateTime
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, at])
}

model ApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  name       String
  keyHash    String
  scopes     String[]
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}
