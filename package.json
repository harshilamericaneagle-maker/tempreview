{
  "name": "reviewhub",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.18.3",
  "scripts": {
    "dev": "turbo dev --parallel",
    "build": "turbo build",
    "lint": "turbo lint --filter=!@reviewhub/web",
    "typecheck": "turbo typecheck --filter=!@reviewhub/web",
    "test": "turbo test --filter=!@reviewhub/web",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "prepare": "husky",
    "db:migrate": "pnpm --filter @reviewhub/db db:migrate",
    "db:seed": "pnpm --filter @reviewhub/db db:seed",
    "db:reset": "pnpm --filter @reviewhub/db db:reset"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@types/node": "^24.9.1",
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.6",
    "prettier": "^3.6.2",
    "turbo": "^2.5.8",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,css}": "prettier --write"
  }
}
